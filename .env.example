# ESG Sentiment Trading Strategy - Environment Variables
# Copy this file to .env and fill in your API keys

# Social Media Data Source (reddit or twitter)
SOCIAL_MEDIA_SOURCE=reddit

# Reddit API Credentials (Recommended - free, unlimited historical access)
# Get credentials from: https://www.reddit.com/prefs/apps
# Click "create app" -> select "script" -> get client_id and secret
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=ESG Sentiment Trading Bot 1.0

# Twitter/X API v2 Credentials (Alternative - free tier limited to 7 days)
# Get your bearer token from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Optional: Twitter API v1.1 credentials (if you have elevated access)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# SEC EDGAR (No API key needed - uses public access)
# Optional: Your email for SEC EDGAR user agent (recommended)
SEC_EDGAR_USER_EMAIL=your_email@example.com

# Database Configuration (Optional - for production)
DATABASE_URL=sqlite:///data/esg_trading.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/esg_trading.log

# Production Settings
PRODUCTION_MODE=false
DRY_RUN=true  # Set to false to execute real trades

# Model Settings
MODEL_PATH=models/enhanced_pipeline
RETRAIN_FREQUENCY_DAYS=30

# Data Settings
DATA_DIR=data
RESULTS_DIR=results
